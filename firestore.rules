
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Helper to check if the authenticated user is the owner of the data.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Admin check via allowlist collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /**
     * @description Helper to check if the authenticated user owns the parent project.
     */
    function isProjectOwner(projectId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    // Admin-only collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /eventLogs/{eventId} {
      allow create: if true; // Telemetry can be created by anyone (visitors)
      allow read: if isAdmin();
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    
    match /systemConfig/product {
      allow read: if true; // Knowledge source for public chat
      allow write: if isAdmin();
    }

    // Visitor chat sessions
    match /visitorChatSessions/{sessionId} {
      allow read, write: if true; // Public chat sessions
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    /**
     * @description Rules for the Project entity and its subcollections.
     */
    match /projects/{projectId} {
      
      // Direct get is public for routing and feed identification
      allow get: if true;
      
      /**
       * @description allow list:
       * 1. Owners listing their own projects (Rules-as-Filters)
       * 2. Admins listing any project
       * 3. Public slug resolution (limit check prevents full enumeration)
       */
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()))
                  || (request.query.limit <= 10);
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      /**
       * @description Allow owner update OR claim if ownerId is currently missing.
       */
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() ||
        (resource.data.ownerId == null && request.resource.data.ownerId == request.auth.uid)
      );
      
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Subcollections using inheritance or direct ownership check

      match /pages/{pageId} {
        // Publicly readable for SEO if marked public OR if owner/admin
        allow read: if resource.data.isPublic == true || isProjectOwner(projectId) || isAdmin();
        
        // Owner/Admin write access
        allow write: if isProjectOwner(projectId) || isAdmin();
      }

      match /generationRuns/{runId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /leads/{leadId} {
        // Leads can be created publicly by any user visiting a feed page
        allow create: if true;
        // Only owner or admin can manage
        allow read, update, delete: if isProjectOwner(projectId) || isAdmin();
      }

      match /customDomains/{domainId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /copilotSessions/{sessionId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
        
        match /messages/{messageId} {
          allow read, write: if isProjectOwner(projectId) || isAdmin();
        }
        
        match /drafts/{draftId} {
          allow read, write: if isProjectOwner(projectId) || isAdmin();
        }
      }
    }
  }
}
