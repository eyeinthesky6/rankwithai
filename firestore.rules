rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Admin check via allowlist collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /**
     * @description Helper to check if the authenticated user owns the parent project.
     */
    function isProjectOwner(projectId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid
      );
    }

    // Admin-only collections
    match /adminUsers/{uid} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /eventLogs/{eventId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /systemConfig/product {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitorChatSessions/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    /**
     * @description Rules for the Project entity.
     */
    match /projects/{projectId} {
      
      // Allow get for anyone (routing/slug resolution)
      allow get: if true;
      
      /**
       * @description allow list logic:
       * 1. Authenticated users can list their OWN projects (requires filter where ownerId == uid).
       * 2. Admins can list any project.
       * 3. Public slug resolution: allowed if the query limit is 1 (prevents scraping).
       */
      allow list: if (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()))
                  || (request.query.limit <= 1);
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid || 
        isAdmin() ||
        (resource.data.ownerId == null && request.resource.data.ownerId == request.auth.uid)
      );
      
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Subcollections
      match /pages/{pageId} {
        allow read: if (resource.data.isPublic == true) || isProjectOwner(projectId) || isAdmin();
        allow list: if (resource.data.isPublic == true && request.query.limit <= 5) || isProjectOwner(projectId) || isAdmin();
        allow write: if isProjectOwner(projectId) || isAdmin();
      }

      match /generationRuns/{runId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /leads/{leadId} {
        allow create: if true;
        allow read, update, delete: if isProjectOwner(projectId) || isAdmin();
      }

      match /customDomains/{domainId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
      }

      match /copilotSessions/{sessionId} {
        allow read, write: if isProjectOwner(projectId) || isAdmin();
        
        match /messages/{messageId} {
          allow read, write: if isProjectOwner(projectId) || isAdmin();
        }
        
        match /drafts/{draftId} {
          allow read, write: if isProjectOwner(projectId) || isAdmin();
        }
      }
    }
  }
}