
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Helper to check if the authenticated user is the owner of the data.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Rules for the Project entity and its subcollections.
     */
    match /projects/{projectId} {
      
      // Project root document rules
      // Split read into get and list for more robust list filtering
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && request.query.limit <= 100 && (resource == null || resource.data.ownerId == request.auth.uid);
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Subcollections

      match /pages/{pageId} {
        // Publicly readable for SEO and feed hosting
        allow read: if true;
        // Only the owner can manage pages
        allow write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /generationRuns/{runId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /leads/{leadId} {
        allow create: if true;
        allow read, update, delete: if isSignedIn() && (
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /customDomains/{domainId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /copilotSessions/{sessionId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
        
        match /messages/{messageId} {
          allow read, write: if isSignedIn() && (
            (resource == null && request.resource.data.ownerId == request.auth.uid) ||
            (resource != null && resource.data.ownerId == request.auth.uid)
          );
        }
        
        match /drafts/{draftId} {
          allow read, write: if isSignedIn() && (
            (resource == null && request.resource.data.ownerId == request.auth.uid) ||
            (resource != null && resource.data.ownerId == request.auth.uid)
          );
        }
      }
    }
  }
}
