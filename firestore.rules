rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Admin check via allowlist collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /**
     * @description Helper to check if the authenticated user owns the document.
     * Assumes document has an 'ownerId' field.
     */
    function isOwner() {
      return isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
    }

    // Admin-only collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /eventLogs/{eventId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /systemConfig/product {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitorChatSessions/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    /**
     * @description Rules for the Project entity.
     * Fixed: Allow public slug resolution while protecting private project lists.
     */
    match /projects/{projectId} {
      
      // Allow individual project lookup by ID for anyone (public feeds need this)
      allow get: if true;
      
      /**
       * @description allow list logic:
       * 1. Slug resolution: allowed for anyone IF the query limit is 1 (prevents scraping).
       * 2. Owners: can list their own projects.
       * 3. Admins: can list any project.
       */
      allow list: if (request.query.limit <= 1)
                  || (isSignedIn() && (isOwner() || isAdmin()));
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && (isOwner() || isAdmin());
      
      allow delete: if isSignedIn() && (isOwner() || isAdmin());

      // Subcollections
      match /pages/{pageId} {
        // Public pages are readable by anyone. Private pages only by owner/admin.
        allow read: if (resource.data.isPublic == true) || isOwner() || isAdmin();
        // Listing pages follows similar logic.
        allow list: if (resource.data.isPublic == true && request.query.limit <= 10) || isOwner() || isAdmin();
        allow write: if isOwner() || isAdmin();
      }

      match /generationRuns/{runId} {
        allow read, write: if isOwner() || isAdmin();
      }

      match /leads/{leadId} {
        allow create: if true;
        allow read, update, delete: if isOwner() || isAdmin();
      }

      match /customDomains/{domainId} {
        allow read, write: if isOwner() || isAdmin();
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isOwner() || isAdmin();
      }

      match /copilotSessions/{sessionId} {
        allow read, write: if isOwner() || isAdmin();
        
        match /messages/{messageId} {
          allow read, write: if isOwner() || isAdmin();
        }
        
        match /drafts/{draftId} {
          allow read, write: if isOwner() || isAdmin();
        }
      }
    }
  }
}