rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /**
     * @description Rules for the Project entity and its subcollections.
     */
    match /projects/{projectId} {
      
      // Allow individual project lookup by ID for anyone
      allow get: if true;
      
      /**
       * @description list rules:
       * 1. Public Resolution: Allow anyone to list projects if limiting to 1 (for slug lookup).
       * 2. Owner Filtering: Allow listing if the query is filtered by the user's UID (ownerId).
       */
      allow list: if (request.query.limit <= 1);
      allow list: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Subcollections inherit ownership check from parent
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid || isAdmin());
      }

      // Specific overrides for subcollections that need public access
      match /pages/{pageId} {
        allow read: if resource.data.isPublic == true;
      }

      match /leads/{leadId} {
        allow create: if true;
      }
    }

    // Global collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /systemConfig/product {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /eventLogs/{eventId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /visitorChatSessions/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}