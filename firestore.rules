rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Rules for the Project entity.
     * Enforces that only the project owner (ownerUid) can access their projects.
     */
    match /projects/{projectId} {
      
      // Enforce ownership for project creation
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      
      // Enforce ownership for read (get/list), update, and delete
      allow read, update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;

      // Subcollections inherit ownership check from parent
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerUid == request.auth.uid;
      }

      // Specific overrides for subcollections that need public access
      match /pages/{pageId} {
        allow read: if resource.data.isPublic == true;
      }

      match /leads/{leadId} {
        allow create: if true;
      }
    }

    // Global collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false; 
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isSignedIn() && request.auth.uid == uid;
    }
    
    match /systemConfig/product {
      allow read: if true;
      allow write: if false;
    }

    match /eventLogs/{eventId} {
      allow create: if true;
      allow read: if false;
    }

    match /visitorChatSessions/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
