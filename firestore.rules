rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Helper to check if the authenticated user is the owner of the data.
     * @param userId The UID to compare against the current authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Rules for the Project entity and its subcollections.
     * We enforce a denormalized ownership model where every document contains an 'ownerId'.
     */
    match /projects/{projectId} {
      
      // Project root document rules
      // For list operations, Firestore requires the rule to match the query filter.
      // We check resource == null to allow queries on empty collections.
      allow read: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Subcollections

      match /pages/{pageId} {
        // Publicly readable for SEO and feed hosting
        allow read: if true;
        // Only the owner can manage pages
        allow write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /brandMemory/{brandMemoryId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /generationRuns/{runId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /leads/{leadId} {
        // Public lead capture form needs to create documents
        allow create: if true;
        // Only the owner can view or manage leads
        allow read, update, delete: if isOwner(resource.data.ownerId);
      }

      match /customDomains/{domainId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }
    }
  }
}
