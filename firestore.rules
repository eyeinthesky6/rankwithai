rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Admin check via allowlist collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    /**
     * @description Helper to check if the authenticated user owns the document.
     */
    function isOwner(data) {
      return isSignedIn() && data.ownerId == request.auth.uid;
    }

    // Admin-only collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /eventLogs/{eventId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    
    match /userProfiles/{uid} {
      allow read, write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }
    
    match /systemConfig/product {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visitorChatSessions/{sessionId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    /**
     * @description Rules for the Project entity.
     */
    match /projects/{projectId} {
      
      // Allow individual project lookup by ID for anyone (public feeds need this)
      allow get: if true;
      
      /**
       * @description list rules:
       * 1. Slug resolution (public): allowed if limit is 1.
       * 2. Owner listing: allowed if query filter matches auth UID.
       * 3. Admin listing: allowed.
       */
      allow list: if (request.query.limit <= 1)
                  || (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()));
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Subcollections
      match /pages/{pageId} {
        allow read: if (resource.data.isPublic == true) || (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()));
        allow list: if (resource.data.isPublic == true && request.query.limit <= 10) 
                    || (isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin()));
        allow write: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /generationRuns/{runId} {
        allow read, list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        allow write: if isSignedIn() && (request.resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /leads/{leadId} {
        allow create: if true;
        allow read, list, update, delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /customDomains/{domainId} {
        allow read, list, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /aiUsageLogs/{logId} {
        allow read, list, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
      }

      match /copilotSessions/{sessionId} {
        allow read, list, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        
        match /messages/{messageId} {
          allow read, list, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        }
        
        match /drafts/{draftId} {
          allow read, list, write: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
        }
      }
    }
  }
}