
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Helper to check if the request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Helper to check if the authenticated user is the owner of the data.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Admin check.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid));
    }

    // Admin-only collections
    match /adminUsers/{uid} {
      allow read: if isSignedIn();
    }
    match /eventLogs/{eventId} {
      allow create: if true; // Telemetry can be created by anyone (visitors)
      allow read: if isAdmin();
    }
    match /userProfiles/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }
    match /systemConfig/product {
      allow read: if true; // Knowledge source for public chat
      allow write: if isAdmin();
    }

    // Visitor chat sessions
    match /visitorChatSessions/{sessionId} {
      allow read, write: if true; // Public chat sessions
      match /messages/{messageId} {
        allow read, write: if true;
      }
    }

    /**
     * @description Rules for the Project entity and its subcollections.
     */
    match /projects/{projectId} {
      
      // Project root document rules
      // Publicly readable for slug lookups in the public feed
      allow get: if true;
      allow list: if isOwner(resource.data.ownerId) || isAdmin(); 
      
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Subcollections

      match /pages/{pageId} {
        // Publicly readable for SEO and feed hosting
        allow read: if true;
        // Only the owner can manage pages
        allow write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
      }

      match /generationRuns/{runId} {
        allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
      }

      match /leads/{leadId} {
        // Leads can be created publicly by any user visiting a feed page
        allow create: if true;
        // Only the owner can manage their leads
        allow read, update, delete: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
      }

      match /customDomains/{domainId} {
        allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
      }

      match /aiUsageLogs/{logId} {
        allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
      }

      match /copilotSessions/{sessionId} {
        allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
        
        match /messages/{messageId} {
          allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
        }
        
        match /drafts/{draftId} {
          allow read, write: if isOwner(resource != null ? resource.data.ownerId : request.resource.data.ownerId);
        }
      }
    }
  }
}
