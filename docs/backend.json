
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A business project for rankwithai content generation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "niche": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "brandMemory": { "$ref": "#/backend/entities/BrandMemory" },
        "lastGenerationHash": { "type": "string", "description": "Hash of brand memory used for the last successful generation." }
      },
      "required": ["id", "ownerId", "name", "slug", "website", "niche", "createdAt"]
    },
    "BrandMemory": {
      "title": "BrandMemory",
      "description": "Enforced structural identity for a business.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "services": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "industries": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "differentiators": { "type": "string" },
        "certifications": { "type": "string" },
        "competitors": { "type": "string" },
        "tone": { "type": "string", "enum": ["Professional", "Technical", "Conversational"] },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            },
            "required": ["question", "answer"]
          }
        }
      },
      "required": ["companyName", "services", "differentiators", "tone"]
    },
    "Page": {
      "title": "Page",
      "description": "AI-generated SEO page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "slug": { "type": "string" },
        "type": { "type": "string", "enum": ["Service+Location", "Service+Industry", "BuyerQuestion"] },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "h1": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "h2": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "faqs": { "type": "array", "items": { "type": "object" } },
        "internalLinks": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "brandMemoryHash": { "type": "string" }
      },
      "required": ["slug", "type", "seoTitle", "metaDescription", "h1", "sections", "createdAt"]
    },
    "GenerationRun": {
      "title": "GenerationRun",
      "description": "Log of a content generation execution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["started", "completed", "failed"] },
        "requestedCount": { "type": "number" },
        "generatedCount": { "type": "number" },
        "aiCalls": { "type": "number" },
        "tokensUsed": { "type": "number" },
        "errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "CopilotSession": {
      "title": "CopilotSession",
      "description": "A chat session with the AI Setup Copilot.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed"] },
        "lastDraft": { "type": "object" }
      }
    },
    "CopilotMessage": {
      "title": "CopilotMessage",
      "description": "A message within a copilot session.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/projects/{projectId}": { "schema": "Project", "description": "Project root." },
    "/projects/{projectId}/pages/{pageId}": { "schema": "Page", "description": "Generated pages." },
    "/projects/{projectId}/generationRuns/{runId}": { "schema": "GenerationRun", "description": "Generation history." },
    "/projects/{projectId}/copilotSessions/{sessionId}": { "schema": "CopilotSession", "description": "Copilot chat session." },
    "/projects/{projectId}/copilotSessions/{sessionId}/messages/{messageId}": { "schema": "CopilotMessage", "description": "Chat messages." }
  }
}
