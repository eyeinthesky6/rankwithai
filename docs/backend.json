
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A business project for rankwithai content generation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "niche": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "brandMemory": { "$ref": "#/backend/entities/BrandMemory" },
        "lastGenerationHash": { "type": "string" },
        "templateVersion": { "type": "number" },
        "customDomainEnabled": { "type": "boolean" },
        "aiUsage": {
          "type": "object",
          "properties": {
            "totalCalls": { "type": "number" },
            "totalTokens": { "type": "number" },
            "lastRunCalls": { "type": "number" },
            "dailyRepairCount": { "type": "number" },
            "lastRepairDate": { "type": "string" }
          }
        },
        "refreshLogs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "pageSlug": { "type": "string" },
              "ruleTriggered": { "type": "string" },
              "metricValue": { "type": "string" },
              "actionTaken": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "ownerUid", "name", "slug", "website", "niche", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSeenAt": { "type": "string", "format": "date-time" }
      }
    },
    "EventLog": {
      "title": "EventLog",
      "properties": {
        "eventType": { "type": "string" },
        "uid": { "type": "string" },
        "projectId": { "type": "string" },
        "pageSlug": { "type": "string" },
        "meta": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "properties": {
        "productDoc": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "VisitorChatSession": {
      "title": "VisitorChatSession",
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessageAt": { "type": "string", "format": "date-time" }
      }
    },
    "VisitorChatMessage": {
      "title": "VisitorChatMessage",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "AIUsageLog": {
      "title": "AIUsageLog",
      "description": "Log of a single AI repair or optimization call.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "actionType": { "type": "string" },
        "tokensEstimated": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "pageSlug": { "type": "string" }
      }
    },
    "CustomDomain": {
      "title": "CustomDomain",
      "description": "Configuration for hosting feeds on a user's custom subdomain.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "requestedDomain": { "type": "string" },
        "status": { "type": "string", "enum": ["REQUESTED", "VERIFYING", "VERIFIED", "ACTIVE", "ERROR"] },
        "verificationToken": { "type": "string" },
        "verificationMethod": { "type": "string", "enum": ["TXT"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "activatedAt": { "type": "string", "format": "date-time" },
        "lastError": { "type": "string" }
      },
      "required": ["projectId", "ownerUid", "requestedDomain", "status", "verificationToken", "createdAt"]
    },
    "BrandMemory": {
      "title": "BrandMemory",
      "description": "Enforced structural identity for a business.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "services": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "industries": { "type": "array", "items": { "type": "string" } },
        "locations": { "type": "array", "items": { "type": "string" } },
        "differentiators": { "type": "string" },
        "certifications": { "type": "string" },
        "competitors": { "type": "string" },
        "tone": { "type": "string", "enum": ["Professional", "Technical", "Conversational"] },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            },
            "required": ["question", "answer"]
          }
        }
      },
      "required": ["companyName", "services", "differentiators", "tone"]
    },
    "Page": {
      "title": "Page",
      "description": "AI-generated SEO page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "slug": { "type": "string" },
        "type": { "type": "string", "enum": ["Service+Location", "Service+Industry", "BuyerQuestion"] },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "h1": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "h2": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "faqs": { "type": "array", "items": { "type": "object" } },
        "internalLinks": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "brandMemoryHash": { "type": "string" },
        "contentScore": { "type": "number" },
        "isStale": { "type": "boolean" },
        "staleReason": { "type": "string" },
        "staleAt": { "type": "string", "format": "date-time" },
        "qaStatus": { "type": "string", "enum": ["OK", "NEEDS_FIX", "FIXED"] },
        "qaIssues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "severity": { "type": "string", "enum": ["low", "medium", "high"] }
            }
          }
        },
        "qaCheckedAt": { "type": "string", "format": "date-time" },
        "lastFixSummary": { "type": "string" },
        "version": { "type": "number" }
      },
      "required": ["slug", "type", "seoTitle", "metaDescription", "h1", "sections", "createdAt"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A lead captured from a public feed page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "pageSlug": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["New", "Contacted", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "ownerUid", "pageSlug", "name", "email", "createdAt"]
    },
    "GenerationRun": {
      "title": "GenerationRun",
      "description": "Log of a content generation execution.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["started", "completed", "failed", "aborted"] },
        "requestedCount": { "type": "number" },
        "generatedCount": { "type": "number" },
        "skippedCount": { "type": "number" },
        "aiCalls": { "type": "number" },
        "tokensUsed": { "type": "number" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "brandMemoryHash": { "type": "string" },
        "abortReason": { "type": "string" }
      }
    },
    "CopilotSession": {
      "title": "CopilotSession",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CopilotMessage": {
      "title": "CopilotMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CopilotDraft": {
      "title": "CopilotDraft",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "ownerUid": { "type": "string" },
        "draftJson": { "type": "object" },
        "confidenceNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "appliedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "/projects/{projectId}": { "schema": "Project", "description": "Project root." },
    "/projects/{projectId}/customDomains/{domainId}": { "schema": "CustomDomain", "description": "Custom domain settings." },
    "/projects/{projectId}/pages/{pageId}": { "schema": "Page", "description": "Generated pages." },
    "/projects/{projectId}/generationRuns/{runId}": { "schema": "GenerationRun", "description": "Generation history." },
    "/projects/{projectId}/leads/{leadId}": { "schema": "Lead", "description": "Captured leads." },
    "/projects/{projectId}/aiUsageLogs/{logId}": { "schema": "AIUsageLog", "description": "Granular AI usage logs." },
    "/projects/{projectId}/copilotSessions/{sessionId}": { "schema": "CopilotSession", "description": "Copilot chat sessions." },
    "/projects/{projectId}/copilotSessions/{sessionId}/messages/{messageId}": { "schema": "CopilotMessage", "description": "Copilot chat messages." },
    "/projects/{projectId}/copilotSessions/{sessionId}/drafts/{draftId}": { "schema": "CopilotDraft", "description": "Copilot identity drafts." },
    "/userProfiles/{uid}": { "schema": "UserProfile", "description": "Aggregated user profiles." },
    "/eventLogs/{eventId}": { "schema": "EventLog", "description": "System telemetry events." },
    "/adminUsers/{uid}": { "schema": "object", "description": "Allowlist for admins." },
    "/systemConfig/product": { "schema": "SystemConfig", "description": "Global product documentation." },
    "/visitorChatSessions/{sessionId}": { "schema": "VisitorChatSession", "description": "Public chat sessions." },
    "/visitorChatSessions/{sessionId}/messages/{messageId}": { "schema": "VisitorChatMessage", "description": "Public chat messages." }
  }
}
