
{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A business project for rankwithai content generation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "website": { "type": "string", "format": "uri" },
        "niche": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name", "slug", "website", "niche", "createdAt"]
    },
    "BrandMemory": {
      "title": "BrandMemory",
      "description": "Enforced structural identity for a business.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "companyName": { "type": "string" },
        "services": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "industries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "locations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "differentiators": { "type": "string" },
        "certifications": { "type": "string" },
        "competitors": { "type": "string" },
        "tone": {
          "type": "string",
          "enum": ["Professional", "Technical", "Conversational"]
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            },
            "required": ["question", "answer"]
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "services", "differentiators", "tone"]
    },
    "Page": {
      "title": "Page",
      "description": "AI-generated SEO page.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "ownerId": { "type": "string" },
        "slug": { "type": "string" },
        "type": { "type": "string", "enum": ["Service+Location", "Service+Industry", "BuyerQuestion"] },
        "seoTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "h1": { "type": "string" },
        "sections": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "h2": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "faqs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "answer": { "type": "string" }
            },
            "required": ["question", "answer"]
          }
        },
        "internalLinks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["slug", "type", "seoTitle", "metaDescription", "h1", "sections", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Root project documents."
    },
    "/projects/{projectId}/brandMemory/{memoryId}": {
      "schema": "BrandMemory",
      "description": "Project brand memory configuration."
    },
    "/projects/{projectId}/pages/{pageId}": {
      "schema": "Page",
      "description": "Generated content pages."
    }
  }
}
